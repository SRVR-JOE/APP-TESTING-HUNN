{
  "name": "luminex-configurator",
  "version": "0.1.0",
  "description": "Luminex GigaCore switch management application",
  "author": "Luminex Configurator Team",
  "license": "MIT",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.node.json && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "postinstall": "echo Skipping electron-rebuild (run manually after installing VS Build Tools)",
    "rebuild": "electron-rebuild",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.6",
    "@tanstack/react-virtual": "^3.11.2",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "bonjour-service": "^1.3.0",
    "date-fns": "^4.1.0",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "ip": "^2.0.1",
    "lucide-react": "^0.460.0",
    "node-arp": "^1.0.6",
    "p-queue": "^6.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "recharts": "^2.14.1",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.2"
  }
}
